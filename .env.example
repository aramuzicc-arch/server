# =============================================================================
# Server environment — copy this file to `.env` and fill in real values.
# Required keys are enforced at startup in `src/config/env.js`.
# =============================================================================
#
# REQUIRED
# --------
# PORT                    HTTP port (default 5050; avoid 5000 on macOS / AirPlay)
# MONGODB_URI             Mongo connection string
# JWT_SECRET              Strong secret for admin JWTs
# CLOUDINARY_CLOUD_NAME   Cloudinary dashboard
# CLOUDINARY_API_KEY
# CLOUDINARY_API_SECRET
#
# RECOMMENDED
# -------------
# CLIENT_ORIGIN           Comma-separated browser origins for CORS (no trailing slash)
# ADMIN_USERNAME          Used by `npm run seed:admin` to upsert the MongoDB admin user
# ADMIN_PASSWORD          Hashed into MongoDB (login checks the DB, not this env var directly)
#
# OPTIONAL — email (contact / bookings / orders notifications)
# ------------------------------------------------------------
# ADMIN_NOTIFY_EMAIL      Where to send admin notifications
# SMTP_HOST SMTP_PORT SMTP_SECURE SMTP_USER SMTP_PASS SMTP_FROM
#
# OPTIONAL — uploads (see `src/middleware/upload.js`)
# -----------------------------------------------------
# UPLOAD_MAX_VIDEO_MB     Default 200
# UPLOAD_MAX_IMAGE_MB     Default 25
#
# OPTIONAL — runtime
# ------------------
# NODE_ENV                `production` or development (affects CORS dev rules & mail logging)
#
# =============================================================================

# Use 5050+ on macOS: System Settings → AirPlay Receiver uses port 5000.
PORT=5050
MONGODB_URI=mongodb://127.0.0.1:27017/ara
JWT_SECRET=replace-with-strong-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
# Create or update admin in MongoDB (required before /admin/login works):
#   npm run seed:admin
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
# Comma-separated for dev + production (CORS). Include every browser origin that calls the API.
# Example: http://localhost:3000,http://127.0.0.1:3000,https://aramuzicc.vercel.app
CLIENT_ORIGIN=http://localhost:3000,https://aramuzicc.vercel.app

# Optional — email admin on new contact, booking, or store order
# ADMIN_NOTIFY_EMAIL=you@example.com
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=ARA Site <noreply@example.com>

# Optional — multer limits (megabytes)
# UPLOAD_MAX_VIDEO_MB=200
# UPLOAD_MAX_IMAGE_MB=25

# Optional — set to production on Vercel / hosted API
# NODE_ENV=production
#
# --- Vercel (Root Directory = server) ---
# Add all required vars above in Project → Settings → Environment Variables.
# CLIENT_ORIGIN must include your deployed frontend origin(s), e.g. https://aramuzicc.vercel.app
# (must match Access-Control-Allow-Origin in server/vercel.json when using credentials).
# MONGODB_URI must be a cloud URI (not 127.0.0.1).
