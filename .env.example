PORT=5050
# Local: mongodb://127.0.0.1:27017/ara
# Vercel: Atlas → Connect → Drivers → copy mongodb+srv://… (not localhost)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/ara?retryWrites=true&w=majority
JWT_SECRET=replace-with-strong-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

