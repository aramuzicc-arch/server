{
  "version": 2,
  "installCommand": "npm install && cd ../client && npm install",
  "buildCommand": "cd ../client && npm run build && cd ../server && rm -rf public && cp -R ../client/dist/public public",
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.js"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
